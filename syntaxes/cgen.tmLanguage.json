{
  "scopeName": "source.cgen",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.cgen",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.cgen",
          "match": "\\bc\\.[A-Za-z_][A-Za-z0-9_.]*\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.cgen",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cgen",
          "match": "\\b(package|module|scope|alias|enum|case|as|fn|template|struct|param|field|use|let|return|mutable|any|none)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cgen",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cgen",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
